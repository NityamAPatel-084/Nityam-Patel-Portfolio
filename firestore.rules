rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net: deny read and write to all unspecified collections
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Core portfolio data collection
    match /portfolio_data/{document} {
      // General public reads allowed for all portfolio data EXCEPT the credentials settings
      allow read: if document != 'settings';
      
      // Dynamic signature verification gate for all writes
      allow write: if (document == 'settings' && !exists(/databases/$(database)/documents/portfolio_data/settings)) ||
                   (request.resource.data.adminSignature != null && 
                    request.resource.data.adminSignature == hashing.sha256((get(/databases/$(database)/documents/portfolio_data/settings).data.adminPassword + '_' + document).toUtf8()).toHexString());
    }
    
    // Resume document and PDF chunks
    match /resume_chunks/{document} {
      // Public reads allowed to retrieve Nityam's physical resume
      allow read: if true;
      
      // Protected chunk writes verified by the same cryptographic signature gate
      allow write: if request.resource.data.adminSignature != null && 
                    request.resource.data.adminSignature == hashing.sha256((get(/databases/$(database)/documents/portfolio_data/settings).data.adminPassword + '_' + document).toUtf8()).toHexString();
    }
  }
}
